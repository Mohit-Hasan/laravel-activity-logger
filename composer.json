{
    "name": "mohit-hasan/laravel-activity-logger",
    "description": "A reusable Laravel package to automatically track and log user actions across the app.",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "MohitHasan\\ActivityLogger\\": "src/"
        }
    },
    "authors": [
        {
            "name": "Mohit Hasan",
            "email": "hello@mohithasan.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "illuminate/support": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/database": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/http": "^10.0|^11.0|^12.0|^13.0"
    },
    "extra": {
        "laravel": {
            "providers": [
                "MohitHasan\\ActivityLogger\\ActivityLoggerServiceProvider"
            ],
            "aliases": {
                "ActivityLogger": "MohitHasan\\ActivityLogger\\Facades\\ActivityLogger"
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
